#!/bin/bash
# Generic ToolCrate Wrapper Script
# This script provides a convenient way to run toolcrate commands

# Get the absolute path to the repository root
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ -f "$REPO_ROOT/.venv/bin/toolcrate" ]; then
    "$REPO_ROOT/.venv/bin/toolcrate" "$@"
elif command -v uv >/dev/null 2>&1 && [ -f "$REPO_ROOT/pyproject.toml" ]; then
    exec uv run --project "$REPO_ROOT" --extra shazam toolcrate "$@"
elif command -v toolcrate >/dev/null 2>&1; then
    toolcrate "$@"
else
    echo "Error: toolcrate not found. Install it with: uv sync --extra shazam" >&2
    exit 1
fi
